# Copy to .env and edit before first deploy: cp .env.example .env

# --- Web UI ---
INSECURE=true
HOST=0.0.0.0
PORT=51821

# --- wg-easy v15 first-boot init (applied once when ./data is empty) ---
INIT_ENABLED=true
INIT_USERNAME=admin
INIT_PASSWORD=

# Public IP or DDNS hostname for client configs / QR codes.
# Must resolve to your home public IP (DNS only — not Cloudflare proxied).
INIT_HOST=vpn.example.com

INIT_PORT=51820
INIT_DNS=1.1.1.1
DISABLE_IPV6=true

# Your home LAN subnet (customize to match your network).
LAN_SUBNET=192.168.1.0/24

# Split tunnel: VPN subnet + home LAN (recommended to start).
INIT_ALLOWED_IPS=10.8.0.0/24,192.168.1.0/24

# Full tunnel (add only after split tunnel works):
# INIT_ALLOWED_IPS=10.8.0.0/24,192.168.1.0/24,0.0.0.0/0
